{
  "manifest_version": 3,
  "name": "OMNI Engine Dashboard",
  "version": "1.0",
  "description": "Visual GUI for the OMNI Multi-Language Compiler",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*" 
  ]
}